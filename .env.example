# Copy to .env and fill in. .env is git-ignored.

# Required: OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: OpenRouter attribution headers (recommended by OpenRouter, not required).
# OPENROUTER_HTTP_REFERER=https://github.com/your/repo
# OPENROUTER_X_TITLE=grok-bench
